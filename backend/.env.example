# =============================================================================
# PropertyPulse — FastAPI backend (copy to backend/.env)
# =============================================================================
# Frontend (Vite) env: see ../.env.example and docs/API_CONFIGURATION.md
# =============================================================================

# Supabase (required for Python backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT verification (use your Supabase JWT secret from Project Settings > API)
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe (for subscriptions) — use test keys (sk_test_..., price_...) for local E2E signup → checkout testing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# E2E checklist:
# 1. Create test Price IDs below (Stripe Dashboard → Products)
# 2. stripe listen --forward-to localhost:8000/api/webhooks/stripe → paste whsec_... above
# 3. Start backend + frontend; sign up → /Pricing?plan=premium → checkout
# 4. Profile?upgraded=1 polls refreshUser until webhook sets profiles.plan
# Test card: 4242 4242 4242 4242, any future expiry, any CVC

# Legacy single price IDs (treated as monthly if interval-specific IDs are not set)
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_REALTOR_PRICE_ID=price_...

# Recommended: separate Price IDs for monthly vs annual billing (create in Stripe Dashboard → Products)
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
STRIPE_REALTOR_MONTHLY_PRICE_ID=price_...
STRIPE_REALTOR_ANNUAL_PRICE_ID=price_...
# RevenueCat webhook secret (Apple IAP entitlement sync to profiles.plan)
REVENUECAT_WEBHOOK_SECRET=replace-with-random-shared-secret
REVENUECAT_PREMIUM_ENTITLEMENT_ID="Property Pocket Pro"
REVENUECAT_REALTOR_ENTITLEMENT_ID=realtor

# OpenAI (PRIMARY LLM — gpt-4o-mini for cost control on user-facing AI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (OPTIONAL fallback only — leave unset to avoid Anthropic spend)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_PROMPT_CACHE_EPHEMERAL=true


# Google APIs (for verified location data and web search)
GOOGLE_PLACES_API_KEY=AIza...
# Required for **Google Auto-Score** (/api/property/autoscore): same key must have these enabled in GCP:
#   • Geocoding API  (maps.googleapis.com/maps/api/geocode)
#   • Places API     (Nearby Search — maps.googleapis.com/maps/api/place/nearbysearch)
# https://console.cloud.google.com/apis/library — search "Geocoding API" and "Places API", Enable both.
# Optional separate server-side key for exterior images. Enable "Street View Static API".
# If blank, GOOGLE_PLACES_API_KEY is used and must also allow Street View Static API.
GOOGLE_STREET_VIEW_API_KEY=
# Optional: AMP URL API (batch canonical → AMP URLs). If unset, GOOGLE_PLACES_API_KEY is used; enable "AMP URL API" on the key's project.
GOOGLE_AMP_URL_API_KEY=
GOOGLE_CSE_ID=your-cse-id

# Verified US property records + active sale listing details (server-side only)
# Create a key: https://app.rentcast.io/app/api
RENTCAST_API_KEY=
# Optional override; default https://api.rentcast.io/v1
RENTCAST_BASE_URL=https://api.rentcast.io/v1
# Shared secret for daily metro refresh (GitHub Actions → POST /api/cron/rentcast-daily-refresh)
CRON_SECRET=

RENTCAST_BASE_URL=https://api.rentcast.io/v1

# Google Sheets — account CRM (contact + account type only; never payment / card data)
# Setup:
#   1. GCP Console → enable "Google Sheets API" on your project
#   2. IAM → Service Accounts → create key (JSON) for a dedicated SA
#   3. Open the spreadsheet → Share → add the SA client_email as Editor
#   4. Railway: set GOOGLE_SHEETS_SA_JSON to the entire JSON key on ONE line (no line breaks)
# Sync runs on GET/PATCH /api/auth/me for every account (upsert by User ID).
# Account deletion sets Account status = Deleted (row is kept for your records).
GOOGLE_MARKETING_SHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_SA_JSON={"type":"service_account","project_id":"your-project",...}
# Share the spreadsheet with the service account client_email as Editor.
# Row 1 is auto-created on first signup sync, or run: python scripts/setup_marketing_sheet.py
# Columns: Signup date | Signup time (UTC) | Name | Email | Phone | Account type | State | Brokerage |
#          Realtor license | Marketing opt-in | Promo code used | Promo code | Account status |
#          Status updated | Source | User ID
# Tab "Promo codes": Code | Status | Benefit | Grants plan | Discount percent | Description |
#          Max uses | Times used | Created | Notes  (seed includes Active code ADMIN)
# Tab is renamed to "Accounts" with frozen header row, filters, and column widths.

# Google Workspace Admin SDK — Data Transfer API (optional; service account + domain-wide delegation)
# https://developers.google.com/workspace/admin/data-transfer/v1/guides
GOOGLE_WORKSPACE_SA_JSON_PATH=
GOOGLE_WORKSPACE_DELEGATED_ADMIN_EMAIL=
# Customer ID (optional; query param can override). Use Google Admin or "my_customer" where supported.
GOOGLE_WORKSPACE_CUSTOMER_ID=
# readonly (admin.datatransfer.readonly) | readwrite (admin.datatransfer; required for POST /transfers)
GOOGLE_WORKSPACE_DATATRANSFER_ACCESS=readonly

# Google AdSense Management API v2 — OAuth for publisher account (optional)
# https://developers.google.com/adsense/management/
GOOGLE_ADSENSE_CLIENT_ID=
GOOGLE_ADSENSE_CLIENT_SECRET=
GOOGLE_ADSENSE_REFRESH_TOKEN=
# readonly (adsense.readonly) | readwrite (full adsense scope; required for AdSense Platform writes: create/close account, sites, events)
GOOGLE_ADSENSE_ACCESS=readonly
# Optional: publisher account for daily revenue snapshots (pub-… or accounts/pub-…). If empty, first account from API is used.
# POST /api/integrations/revenue/adsense-daily-snapshot (admin) — see docs/PUBLISHER_REVENUE_ADSENSE_STRIPE.md
GOOGLE_ADSENSE_PUBLISHER_ACCOUNT=
# AdSense Platform API (Google v1alpha; A4P + Transparent Platform) uses the same OAuth vars. Proxy: /api/integrations/google/adsense-platform/v1alpha/...

# Google DoubleClick Search API v2 (Search Ads 360) — OAuth refresh token; scope https://www.googleapis.com/auth/doubleclicksearch
# https://developers.google.com/search-ads/reporting/api/v2/getting-started
# Proxy: GET/POST /api/integrations/google/doubleclicksearch/v2/{path} e.g. agency/{id}/advertiser/{id}/idmapping
GOOGLE_DOUBLECLICKSEARCH_CLIENT_ID=
GOOGLE_DOUBLECLICKSEARCH_CLIENT_SECRET=
GOOGLE_DOUBLECLICKSEARCH_REFRESH_TOKEN=
# Optional host only (default https://www.googleapis.com)
GOOGLE_DOUBLECLICKSEARCH_BASE_URL=

# Google Analytics Hub API v1 — service account JSON (enable Analytics Hub API on the GCP project)
# https://cloud.google.com/bigquery/docs/analytics-hub-introduction
# readonly (bigquery.readonly) | readwrite (bigquery; default) | cloud_platform (full GCP OAuth scope)
GOOGLE_ANALYTICS_HUB_SA_JSON_PATH=
GOOGLE_ANALYTICS_HUB_ACCESS=readwrite
# Frontend: VITE_GOOGLE_ANALYTICS_HUB_API_VERSION=v1 (default) or v1beta1 — must match Google API path segment.

# Google Android Management API v1 — enterprise device management (service account; enable API on GCP project)
# https://developers.google.com/android/management
GOOGLE_ANDROID_MANAGEMENT_SA_JSON_PATH=

# Google Chat API v1 — service account (+ optional domain-wide delegation user)
# https://developers.google.com/workspace/chat
GOOGLE_CHAT_SA_JSON_PATH=
# Optional: Workspace user email to impersonate (requires domain-wide delegation for GOOGLE_CHAT_SCOPES)
GOOGLE_CHAT_IMPERSONATE_EMAIL=
# Comma-separated OAuth scopes; if empty, defaults to https://www.googleapis.com/auth/chat.bot
# Add e.g. chat.spaces, chat.messages, chat.memberships as needed for user-context calls.
GOOGLE_CHAT_SCOPES=

# Chrome Web Store API v2 — service account (enable API on GCP; see https://developer.chrome.com/docs/webstore/api)
GOOGLE_CHROME_WEBSTORE_SA_JSON_PATH=
# readonly (chromewebstore.readonly; fetchStatus only) | readwrite (publish, upload, cancel, deploy %)
GOOGLE_CHROME_WEBSTORE_ACCESS=readwrite

# Google Cloud Data Fusion API — service account (cloud-platform; enable Data Fusion API)
# https://cloud.google.com/data-fusion/docs
# Proxy exposes both /api/integrations/google/data-fusion/v1/... and .../v1beta1/... (beta adds upgrade, removeIamPolicy, namespaces).
GOOGLE_DATA_FUSION_SA_JSON_PATH=
# Optional: regional API base, e.g. https://datafusion.us-central1.rep.googleapis.com (default: https://datafusion.googleapis.com)
GOOGLE_DATA_FUSION_BASE_URL=

# Google Cloud Filestore API — service account (cloud-platform; enable Filestore API)
# https://cloud.google.com/filestore/
# Proxy: /api/integrations/google/filestore/v1/... and .../v1beta1/... (beta adds multi-share instance shares API).
GOOGLE_FILESTORE_SA_JSON_PATH=
# Optional; default https://file.googleapis.com
GOOGLE_FILESTORE_BASE_URL=

# Google Cloud OS Login API v1 — service account (cloud-platform; enable OS Login API / IAM as needed)
# https://cloud.google.com/compute/docs/oslogin/
GOOGLE_OSLOGIN_SA_JSON_PATH=
GOOGLE_OSLOGIN_BASE_URL=

# Google Cloud Translation API v3 / v3beta1 — service account (cloud-platform; enable Cloud Translation API)
# Proxy: /api/integrations/google/translate/v3/... and .../v3beta1/... (beta is a smaller method set)
# https://cloud.google.com/translate/docs/
GOOGLE_TRANSLATE_SA_JSON_PATH=
# Optional; default https://translation.googleapis.com
GOOGLE_TRANSLATE_BASE_URL=

# Google Data Manager API v1 — service account (enable Data Manager API; scope https://www.googleapis.com/auth/datamanager)
# https://developers.google.com/data-manager
# Proxy: /api/integrations/google/datamanager/v1/...
GOOGLE_DATAMANAGER_SA_JSON_PATH=
# Optional; default https://datamanager.googleapis.com
GOOGLE_DATAMANAGER_BASE_URL=

# Google Drive API v3 — service account (enable Drive API; optional domain-wide delegation to a user)
# https://developers.google.com/workspace/drive/
# Proxy passthrough:
#   /api/integrations/google/drive/v3/{path}           → https://www.googleapis.com/drive/v3/{path}
#   /api/integrations/google/drive/upload/v3/{path}   → https://www.googleapis.com/upload/drive/v3/{path}
#   /api/integrations/google/drive/resumable/v3/{path} → https://www.googleapis.com/resumable/upload/drive/v3/{path}
GOOGLE_DRIVE_SA_JSON_PATH=
# Optional: Workspace user email to impersonate (requires domain-wide delegation for GOOGLE_DRIVE_SCOPES)
GOOGLE_DRIVE_IMPERSONATE_EMAIL=
# Comma-separated OAuth scopes; if empty, defaults to https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_SCOPES=
# Optional; default https://www.googleapis.com
GOOGLE_DRIVE_BASE_URL=

# Google Policy Analyzer API v1 — service account (cloud-platform; enable Policy Analyzer API)
# Proxy: GET /api/integrations/google/policyanalyzer/v1/{projects|organizations|folders}/{id}/locations/{loc}/activityTypes/{type}/activities:query
GOOGLE_POLICYANALYZER_SA_JSON_PATH=
# Optional; default https://policyanalyzer.googleapis.com
GOOGLE_POLICYANALYZER_BASE_URL=

# Google Policy Simulator API v1 — service account (cloud-platform; enable Policy Simulator API)
# https://cloud.google.com/iam/docs/simulating-access
# Proxy passthrough:
#   /api/integrations/google/policysimulator/v1/{path}     → https://policysimulator.googleapis.com/v1/{path}
#   /api/integrations/google/policysimulator/v1beta/{path} → https://policysimulator.googleapis.com/v1beta/{path}
GOOGLE_POLICYSIMULATOR_SA_JSON_PATH=
# Optional; default https://policysimulator.googleapis.com
GOOGLE_POLICYSIMULATOR_BASE_URL=

# Google SaaS Runtime API (saasservicemgmt) — service account (cloud-platform; enable SaaS Runtime API)
# https://cloud.google.com/saas-runtime/docs
# Proxy passthrough:
#   /api/integrations/google/saasservicemgmt/v1/{path}     → https://saasservicemgmt.googleapis.com/v1/{path}
#   /api/integrations/google/saasservicemgmt/v1beta1/{path} → https://saasservicemgmt.googleapis.com/v1beta1/{path}
GOOGLE_SAASSERVICEMGMT_SA_JSON_PATH=
# Optional; default https://saasservicemgmt.googleapis.com
GOOGLE_SAASSERVICEMGMT_BASE_URL=

# Google Service Networking API v1 — service account (cloud-platform; enable Service Networking API)
# https://cloud.google.com/service-infrastructure/docs/service-networking/getting-started
# Proxy: /api/integrations/google/servicenetworking/v1/{path} → https://servicenetworking.googleapis.com/v1/{path}
GOOGLE_SERVICENETWORKING_SA_JSON_PATH=
# Optional; default https://servicenetworking.googleapis.com
GOOGLE_SERVICENETWORKING_BASE_URL=

# CORS (comma-separated origins, e.g. http://localhost:5173,https://yourapp.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://house-app-rho.vercel.app

# Public web app URL (invite links, Stripe success/cancel/portal return URLs — match your Vite app origin)
APP_PUBLIC_URL=http://localhost:5173
# Stripe Checkout terms: set Terms of service URL in Stripe Dashboard → Settings → Business → Public details
# to {APP_PUBLIC_URL}/Terms so consent_collection works during checkout.

# --- End-to-end signup + subscription test checklist ---
# 1. Supabase Dashboard → Authentication → Providers → Email:
#    Disable "Confirm email" for fastest local testing, OR keep enabled and click the confirm link before checkout.
# 2. Supabase → Authentication → URL Configuration: Site URL = http://localhost:5173, add redirect URLs for /login
# 3. Frontend .env.local: VITE_USE_SUPABASE=true, VITE_USE_PYTHON_BACKEND=true, VITE_API_BASE_URL=http://localhost:8000
# 4. Backend .env: SUPABASE_*, STRIPE_* test keys, APP_PUBLIC_URL=http://localhost:5173, CORS_ORIGINS=http://localhost:5173
# 5. Terminal A: cd backend && uvicorn app.main:app --reload --port 8000
# 6. Terminal B: cd .. && npm run dev
# 7. Terminal C (optional, for plan sync after checkout): stripe listen --forward-to localhost:8000/api/webhooks/stripe
# 8. Flow: /login → Create account → /Pricing → Upgrade → Stripe test card 4242... → Profile billing shows Premium


# Comma-separated Supabase user UUIDs allowed as platform admins (AdSense revenue API, etc.) without profiles.plan=admin
# Example: PLATFORM_ADMIN_USER_IDS=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
PLATFORM_ADMIN_USER_IDS=

# Resend (signup codes, activity emails, in-app feedback → SUPPORT_EMAIL)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Property Pocket <noreply@yourdomain.com>"
# SUPPORT_EMAIL=support@proppocket.com

# Optional: server port
PORT=8000
