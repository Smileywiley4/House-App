# Supabase (required for Python backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT verification (use your Supabase JWT secret from Project Settings > API)
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_REALTOR_PRICE_ID=price_...

# Anthropic Claude (PRIMARY LLM — preferred for accuracy)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (FALLBACK LLM — used only if Anthropic key is not set)
OPENAI_API_KEY=sk-...

# Google APIs (for verified location data and web search)
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_CSE_ID=your-cse-id

# CORS (comma-separated origins, e.g. http://localhost:5173,https://yourapp.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: server port
PORT=8000
