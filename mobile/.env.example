# Public web URL used in invites/deep links (no trailing slash)
EXPO_PUBLIC_APP_URL=https://your-prop-pocket-app.example.com

# FastAPI base URL for optional device snapshot endpoint
# Used by utils/localDeviceStats.js when consent is enabled
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com

# RevenueCat iOS public SDK key (production/release builds — App Store)
EXPO_PUBLIC_RC_APPLE_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxx
# RevenueCat Android public SDK key (optional unless shipping Android purchase flow)
EXPO_PUBLIC_RC_GOOGLE_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxx
# RevenueCat Test Store key (test_...) — dev/debug only; never in App Store builds
EXPO_PUBLIC_RC_TEST_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxx
# Entitlement id you mark active for paid users
EXPO_PUBLIC_IAP_ENTITLEMENT_ID="Property Pocket Pro"
# Optional: Supabase user UUID for dev webhook sync testing (calls Purchases.logIn)
# EXPO_PUBLIC_IAP_DEBUG_USER_ID=your-supabase-user-uuid
