{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_IAP_ENTITLEMENT_ID": "Property Pocket Pro",
        "EXPO_PUBLIC_APP_URL": "https://house-app-rho.vercel.app",
        "EXPO_PUBLIC_API_BASE_URL": "https://house-app-production-cfea.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_IAP_ENTITLEMENT_ID": "Property Pocket Pro",
        "EXPO_PUBLIC_APP_URL": "https://house-app-rho.vercel.app",
        "EXPO_PUBLIC_API_BASE_URL": "https://house-app-production-cfea.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_IAP_ENTITLEMENT_ID": "Property Pocket Pro",
        "EXPO_PUBLIC_APP_URL": "https://house-app-rho.vercel.app",
        "EXPO_PUBLIC_API_BASE_URL": "https://house-app-production-cfea.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID_EMAIL",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_NUMERIC_APP_ID"
      }
    }
  }
}
