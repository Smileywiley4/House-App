{
  "expo": {
    "name": "Property Pocket",
    "slug": "property-pocket-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "proppocket",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.proppocket.mobile",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Property Pocket uses the camera to capture in-person photos of homes you visit.",
        "NSPhotoLibraryUsageDescription": "Property Pocket can read your photo library when you choose existing photos for visit notes.",
        "NSPhotoLibraryAddUsageDescription": "Property Pocket saves visit photos you take to your photo library when you choose Save to Photos.",
        "NSLocationWhenInUseUsageDescription": "Property Pocket uses your location to show where you are on the map and nearby homes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.proppocket.mobile",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#10b981",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10b981",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image",
        {
          "disableLibdav1d": true
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-sharing",
        {
          "ios": {
            "enabled": true,
            "activationRule": {
              "supportsImageWithMaxCount": 5
            }
          },
          "android": {
            "enabled": true,
            "singleShareMimeTypes": [
              "image/*"
            ],
            "multipleShareMimeTypes": [
              "image/*"
            ]
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Property Pocket to access your photos when you pick images for property visits.",
          "savePhotosPermission": "Allow Property Pocket to save visit photos you capture to your library.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Property Pocket to use the camera for in-person property visit photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Property Pocket uses your location to show where you are on the map and nearby homes."
        }
      ],
      "expo-status-bar"
    ]
  }
}
