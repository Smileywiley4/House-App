# =============================================================================
# PropertyPulse — Vite frontend (copy to .env or .env.local in this folder)
# =============================================================================
# SEO (production build): canonical URLs, Open Graph base, sitemap.xml generation
# VITE_SITE_URL=https://your-production-domain.com
# Optional 1200x630 absolute image URL for social previews
# VITE_OG_IMAGE_URL=https://your-production-domain.com/og-image.png
# =============================================================================
# Server secrets and all Google service accounts: see backend/.env.example
# Full matrix: docs/API_CONFIGURATION.md
# =============================================================================

# --- Supabase (browser-safe keys only) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Bot protection (Cloudflare Turnstile site key; secret goes in Supabase Auth CAPTCHA) ---
# See docs/CAPTCHA_SETUP.md
# VITE_TURNSTILE_SITE_KEY=

# --- Which adapters to use ---
# true = Supabase client for auth/session
VITE_USE_SUPABASE=true
# true = FastAPI for LLM, Stripe checkout, Google proxies, library, invites, etc.
VITE_USE_PYTHON_BACKEND=true

# --- Python backend (no trailing slash) ---
VITE_API_BASE_URL=http://localhost:8000

# --- Local signup + Stripe checkout test (see backend/.env.example checklist) ---
# VITE_USE_SUPABASE=true and VITE_USE_PYTHON_BACKEND=true are required for full auth + billing flow.

# Optional: Google Maps Embed API key (interactive iframe when property has no lat/lng)
# VITE_GOOGLE_MAPS_EMBED_KEY=

# --- Support & trust (public-facing) ---
# VITE_SUPPORT_EMAIL=support@yourdomain.com
# VITE_SUPPORT_URL=https://your-production-domain.com/Support

# --- Optional: Analytics Hub proxy path version (default v1) ---
# VITE_GOOGLE_ANALYTICS_HUB_API_VERSION=v1
# VITE_GOOGLE_ANALYTICS_HUB_API_VERSION=v1beta1

# --- Optional: Google Maps Embed API (property map on Home) ---
# Without this key, maps use OpenStreetMap via Leaflet (no key required).
# Enable "Maps Embed API" in Google Cloud and restrict the key to your domain + Embed API.
# VITE_GOOGLE_MAPS_EMBED_KEY=

# --- Optional: on-page Google AdSense (publisher display ads; not the Google Ads advertiser API) ---
# Publisher ID from AdSense (format ca-pub-XXXXXXXX). Ad units: Ads → By ad unit → get slot IDs.
# OAuth for Management API (reports) is separate — backend/scripts/adsense_oauth_to_env.py
#
# Local dev: if you omit the vars below, `npm run dev` uses Google’s sample test client+slot automatically
# (see src/components/AdSlot.jsx). Opt out: VITE_GOOGLE_ADS_DEMO=false
# Production builds: you must set your real ca-pub + slots, or slots stay empty.
#
# VITE_GOOGLE_ADS_CLIENT_ID=ca-pub-XXXXXXXX
# VITE_GOOGLE_ADS_SLOT_LEADERBOARD=
# VITE_GOOGLE_ADS_SLOT_INFEED=
# Optional: dedicated medium rectangle unit (else falls back to leaderboard slot)
# VITE_GOOGLE_ADS_SLOT_RECTANGLE=
# Legacy aliases: VITE_GOOGLE_ADS_SLOT_1, VITE_GOOGLE_ADS_SLOT_2
#
# Optional explicit Google sample IDs (same as dev fallback — safe test ads only):
# VITE_GOOGLE_ADS_CLIENT_ID=ca-pub-3940256099942544
# VITE_GOOGLE_ADS_SLOT_LEADERBOARD=6300978111
# VITE_GOOGLE_ADS_SLOT_INFEED=6300978111
# VITE_GOOGLE_ADS_SLOT_RECTANGLE=6300978111

# --- Optional: Base44 platform ---
# VITE_BASE44_APP_ID=
# VITE_BASE44_BACKEND_URL=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=

# =============================================================================
# E2E signup → subscription checklist (Stripe test mode)
# =============================================================================
# 1. Copy backend/.env.example → backend/.env; set STRIPE_SECRET_KEY=sk_test_...
# 2. Create Premium/Realtor test Price IDs in Stripe Dashboard; set STRIPE_*_PRICE_ID vars
# 3. Terminal A: cd backend && uvicorn main:app --reload --port 8000
# 4. Terminal B: stripe listen --forward-to localhost:8000/api/webhooks/stripe
#    → paste whsec_... into backend/.env STRIPE_WEBHOOK_SECRET
# 5. Copy this file → .env.local; set VITE_USE_PYTHON_BACKEND=true, VITE_API_BASE_URL
# 6. npm run dev → Sign up → /Pricing?plan=premium → checkout → return to Profile?tab=billing
# 7. Confirm plan updates (webhook may lag ~2–10s; Profile polls refreshUser automatically)
# =============================================================================
