# =============================================================================
# PropertyPulse — Vite frontend (copy to .env or .env.local in this folder)
# =============================================================================
# Server secrets and all Google service accounts: see backend/.env.example
# Full matrix: docs/API_CONFIGURATION.md
# =============================================================================

# --- Supabase (browser-safe keys only) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Which adapters to use ---
# true = Supabase client for auth/session
VITE_USE_SUPABASE=true
# true = FastAPI for LLM, Stripe checkout, Google proxies, library, invites, etc.
VITE_USE_PYTHON_BACKEND=true

# --- Python backend (no trailing slash) ---
VITE_API_BASE_URL=http://localhost:8000

# --- Optional: Analytics Hub proxy path version (default v1) ---
# VITE_GOOGLE_ANALYTICS_HUB_API_VERSION=v1
# VITE_GOOGLE_ANALYTICS_HUB_API_VERSION=v1beta1

# --- Optional: on-page Google AdSense (publisher display ads; not the Google Ads advertiser API) ---
# Publisher ID from AdSense (format ca-pub-XXXXXXXX). Ad units: Ads → By ad unit → get slot IDs.
# OAuth for Management API (reports) is separate — backend/scripts/adsense_oauth_to_env.py
#
# Local dev: if you omit the vars below, `npm run dev` uses Google’s sample test client+slot automatically
# (see src/components/AdSlot.jsx). Opt out: VITE_GOOGLE_ADS_DEMO=false
# Production builds: you must set your real ca-pub + slots, or slots stay empty.
#
# VITE_GOOGLE_ADS_CLIENT_ID=ca-pub-XXXXXXXX
# VITE_GOOGLE_ADS_SLOT_LEADERBOARD=
# VITE_GOOGLE_ADS_SLOT_INFEED=
# Optional: dedicated medium rectangle unit (else falls back to leaderboard slot)
# VITE_GOOGLE_ADS_SLOT_RECTANGLE=
# Legacy aliases: VITE_GOOGLE_ADS_SLOT_1, VITE_GOOGLE_ADS_SLOT_2
#
# Optional explicit Google sample IDs (same as dev fallback — safe test ads only):
# VITE_GOOGLE_ADS_CLIENT_ID=ca-pub-3940256099942544
# VITE_GOOGLE_ADS_SLOT_LEADERBOARD=6300978111
# VITE_GOOGLE_ADS_SLOT_INFEED=6300978111
# VITE_GOOGLE_ADS_SLOT_RECTANGLE=6300978111

# --- Optional: Base44 platform ---
# VITE_BASE44_APP_ID=
# VITE_BASE44_BACKEND_URL=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=
